#!/bin/sh
# zram compressed swap for memory-constrained boards
# Gives ~8MB effective swap from 4MB RAM (lzo compression ~2:1)

case "$1" in
  start)
    echo "Setting up zram swap..."
    modprobe zram 2>/dev/null
    echo lzo > /sys/block/zram0/comp_algorithm
    echo 4M > /sys/block/zram0/disksize
    mkswap /dev/zram0 >/dev/null 2>&1
    swapon -p 100 /dev/zram0
    echo 10 > /proc/sys/vm/swappiness
    echo "zram swap enabled (4MB, lzo)"
    ;;
  stop)
    echo "Disabling zram swap..."
    swapoff /dev/zram0 2>/dev/null
    ;;
  *)
    echo "Usage: $0 {start|stop}"
    exit 1
    ;;
esac
exit 0
