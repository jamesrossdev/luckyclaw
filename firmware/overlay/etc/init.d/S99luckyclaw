#!/bin/sh
# LuckyClaw auto-start service
# Dynamically configured for Luckfox Pico boards (Plus/Pro/Max)

DAEMON=/usr/bin/luckyclaw
PIDFILE=/var/run/luckyclaw.pid
LOGFILE=/var/log/luckyclaw.log
CONFIGFILE=/oem/.luckyclaw/config.json

# Aggressive GC for embedded devices (see AGENTS.md Lesson 3)
# Triggers GC when heap grows 20% (vs default 100%) to keep RSS small
export GOGC=20

export PATH=$PATH:/usr/bin:/usr/local/bin:/sbin:/bin

detect_memory_profile() {
    local total_mem_kb=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    local total_mem_mb=$((total_mem_kb / 1024))

    # MemTotal-based detection (stable, hardware-constant)
    # Pico Plus:  ≤ 60 MB total (64MB DDR2)  → GOMEMLIMIT=24MiB
    # Pico Pro:   61-200 MB total (128MB DDR3) → GOMEMLIMIT=48MiB
    # Pico Max:   > 200 MB total (256MB DDR3) → GOMEMLIMIT=96MiB

    if [ "$total_mem_mb" -gt 200 ]; then
        export GOMEMLIMIT=96MiB
        logger -t luckyclaw "Detected Pico Max (${total_mem_mb}MB) - GOMEMLIMIT=96MiB"
    elif [ "$total_mem_mb" -gt 60 ]; then
        export GOMEMLIMIT=48MiB
        logger -t luckyclaw "Detected Pico Pro (${total_mem_mb}MB) - GOMEMLIMIT=48MiB"
    else
        export GOMEMLIMIT=24MiB
        logger -t luckyclaw "Detected Pico Plus (${total_mem_mb}MB) - GOMEMLIMIT=24MiB"
    fi
}

# Read timezone from onboarding config (UTC fallback)
get_timezone_from_config() {
    if [ -f "$CONFIGFILE" ]; then
        tz=$(grep -o '"timezone_name"[[:space:]]*:[[:space:]]*"[^"]*"' "$CONFIGFILE" 2>/dev/null | sed 's/.*: *"\([^"]*\)".*/\1/')
        if [ -n "$tz" ]; then
            export TZ="$tz"
            return
        fi
    fi
    export TZ="UTC"
}

# Override DHCP with static IP if configured (Luckfox vendor scripts start udhcpc after ifup)
override_static_ip() {
    if grep -q "inet static" /etc/network/interfaces 2>/dev/null; then
        # Kill any udhcpc that overwrote our static config
        killall -9 udhcpc 2>/dev/null
        # Reapply static config from interfaces file
        ifdown eth0 2>/dev/null
        ifup eth0 2>/dev/null
        logger -t luckyclaw "Static IP override: applied from /etc/network/interfaces"
    fi
}

# Ensure Telegram API resolves (fasthttp DNS timeout workaround)
grep -q "api.telegram.org" /etc/hosts 2>/dev/null || \
  echo "149.154.166.110 api.telegram.org" >> /etc/hosts

# Kill ADB daemon to save RAM (~1.5MB)
if [ -f /etc/init.d/S90adbd ]; then
  /etc/init.d/S90adbd stop 2>/dev/null
fi
killall -9 adbd 2>/dev/null

# Apply memory and timezone settings
detect_memory_profile
get_timezone_from_config

# Override DHCP with static IP if configured (runs after vendor udhcpc)
override_static_ip

case "$1" in
  start)
    # Check if config exists (user needs to run 'luckyclaw onboard' first)
    if [ ! -f "$CONFIGFILE" ]; then
      echo "LuckyClaw: No config found at $CONFIGFILE. Run 'luckyclaw onboard' first."
      exit 0
    fi
    echo "Starting LuckyClaw..."

    # Wait for NTP to sync the system clock before starting.
    # The Luckfox has no battery-backed RTC, so the clock starts at 1970
    # on cold boot. TLS connections fail until NTP corrects it because
    # certificates are "not yet valid". Discord's library does not retry
    # after a TLS failure, so launching too early kills it permanently.
    NTP_WAIT=0
    while [ "$(date +%Y)" -lt 2025 ] && [ "$NTP_WAIT" -lt 30 ]; do
      sleep 1
      NTP_WAIT=$((NTP_WAIT + 1))
    done
    if [ "$(date +%Y)" -lt 2025 ]; then
      echo "LuckyClaw: WARNING - System clock not synced after 30s, starting anyway"
    fi

    # NOTE: start-stop-daemon -b redirects fd 0/1/2 to /dev/null BEFORE
    # shell redirection takes effect, making >> $LOGFILE 2>&1 useless.
    # Use sh -c wrapper to daemonize with proper log capture instead.
    start-stop-daemon -S -b -m -p $PIDFILE \
      -x /bin/sh -- -c "exec $DAEMON gateway >> $LOGFILE 2>&1"

    # Protect from OOM killer
    sleep 1
    if [ -f $PIDFILE ]; then
      echo -200 > /proc/$(cat $PIDFILE)/oom_score_adj 2>/dev/null
    fi
    ;;
  stop)
    echo "Stopping LuckyClaw..."
    start-stop-daemon -K -p $PIDFILE 2>/dev/null
    # Kill luckyclaw gateway processes (start-stop-daemon excludes calling process)
    start-stop-daemon -K -x $DAEMON -- --gateway 2>/dev/null
    rm -f $PIDFILE
    ;;
  restart)
    $0 stop
    sleep 2
    $0 start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac
exit 0
