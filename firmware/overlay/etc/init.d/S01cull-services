#!/bin/sh
# Disable unnecessary services for LuckyClaw AI assistant

case "$1" in
  start)
    # Android Debug Bridge — not needed, SSH available
    killall adbd 2>/dev/null
    # Telnet daemon — insecure, SSH available
    killall telnetd 2>/dev/null
    # Kernel log daemon — redundant with syslogd
    killall klogd 2>/dev/null
    ;;
  *)
    echo "Usage: $0 {start}"
    ;;
esac
exit 0
